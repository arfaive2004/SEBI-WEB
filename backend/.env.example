# Secret used to sign JWT auth tokens. Set this to a long random string in production.
JWT_SECRET_KEY=change-this-to-a-long-random-string

# Optional: a full database URL (e.g. Postgres from Neon/Supabase/Vercel Postgres).
# If unset, the app falls back to a local SQLite file. On Vercel's serverless
# runtime that SQLite file lives in /tmp and is wiped on cold starts, so for
# real production data (not just a demo), set DATABASE_URL to a hosted Postgres DB.
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Comma-separated list of allowed frontend origins for CORS, or "*" for any origin.
CORS_ORIGINS=*
